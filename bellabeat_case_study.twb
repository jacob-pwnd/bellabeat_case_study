    <worksheet name='Non-Sedentary Activity Breakdown'>
      <table>
        <view>
          <datasources>
            <datasource caption='activity_daily+' name='federated.1nxtfoj07jduyd1d011j10jnof34' />
          </datasources>
          <datasource-dependencies datasource='federated.1nxtfoj07jduyd1d011j10jnof34'>
            <column caption='Time Very Active ' datatype='real' name='[Calculation_0345854129127428]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([VeryActiveMinutes])/(SUM([VeryActiveMinutes]) + SUM([FairlyActiveMinutes]) + SUM([LightlyActiveMinutes]))' />
            </column>
            <column caption='Time Moderately Active' datatype='real' name='[Calculation_0345854129684485]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([FairlyActiveMinutes])/(SUM([VeryActiveMinutes]) + SUM([FairlyActiveMinutes]) + SUM([LightlyActiveMinutes]))' />
            </column>
            <column caption='Time Lightly Active' datatype='real' name='[Calculation_0345854129827846]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([LightlyActiveMinutes])/(SUM([VeryActiveMinutes]) + SUM([FairlyActiveMinutes]) + SUM([LightlyActiveMinutes]))' />
            </column>
            <column caption='Moderately Active Minutes' datatype='integer' name='[FairlyActiveMinutes]' role='measure' type='quantitative' />
            <column caption='Lightly Active Minutes' datatype='integer' name='[LightlyActiveMinutes]' role='measure' type='quantitative' />
            <column caption='Very Active Minutes' datatype='integer' name='[VeryActiveMinutes]' role='measure' type='quantitative' />
            <column-instance column='[FairlyActiveMinutes]' derivation='Sum' name='[sum:FairlyActiveMinutes:qk]' pivot='key' type='quantitative' />
