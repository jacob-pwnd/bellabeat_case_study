  <worksheets>
    <worksheet name='Active vs Sedentary Minutes'>
      <table>
        <view>
          <datasources>
            <datasource caption='activity_daily+' name='federated.1nxtfoj07jduyd1d011j10jnof34' />
          </datasources>
          <datasource-dependencies datasource='federated.1nxtfoj07jduyd1d011j10jnof34'>
            <column caption='Average Intensity' datatype='real' name='[AverageIntensity]' role='measure' type='quantitative' />
            <column caption='Active' datatype='real' name='[Calculation_1128156687773696]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([LightlyActiveMinutes])+SUM([FairlyActiveMinutes])+SUM([VeryActiveMinutes]))/(SUM([LightlyActiveMinutes])+SUM([FairlyActiveMinutes])+SUM([VeryActiveMinutes])+SUM([SedentaryMinutes]))' />
            </column>
            <column caption='Sedentary' datatype='real' name='[Calculation_1128156690063361]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([SedentaryMinutes])/(SUM([LightlyActiveMinutes])+SUM([FairlyActiveMinutes])+SUM([VeryActiveMinutes])+SUM([SedentaryMinutes]))' />
            </column>
            <column caption='Moderately Active Minutes' datatype='integer' name='[FairlyActiveMinutes]' role='measure' type='quantitative' />
            <column caption='Lightly Active Minutes' datatype='integer' name='[LightlyActiveMinutes]' role='measure' type='quantitative' />
            <column caption='Sedentary Minutes' datatype='integer' name='[SedentaryMinutes]' role='measure' type='quantitative' />
            <column caption='Total Distance' datatype='real' name='[TotalDistance]' role='measure' type='quantitative' />
            <column caption='Very Active Minutes' datatype='integer' name='[VeryActiveMinutes]' role='measure' type='quantitative' />
            <column-instance column='[AverageIntensity]' derivation='Sum' name='[sum:AverageIntensity:qk]' pivot='key' type='quantitative' />
            <column-instance column='[SedentaryMinutes]' derivation='Sum' name='[sum:SedentaryMinutes:qk]' pivot='key' type='quantitative' />
            <column-instance column='[TotalDistance]' derivation='Sum' name='[sum:TotalDistance:qk]' pivot='key' type='quantitative' />
