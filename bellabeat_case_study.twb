      <column caption='Very Active ' datatype='real' name='[Calculation_0345854129127428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([VeryActiveMinutes])/(SUM([VeryActiveMinutes]) + SUM([FairlyActiveMinutes]) + SUM([LightlyActiveMinutes]))' />
      </column>
      <column caption='Moderately Active' datatype='real' name='[Calculation_0345854129684485]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FairlyActiveMinutes])/(SUM([VeryActiveMinutes]) + SUM([FairlyActiveMinutes]) + SUM([LightlyActiveMinutes]))' />
      </column>
      <column caption='Lightly Active' datatype='real' name='[Calculation_0345854129827846]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([LightlyActiveMinutes])/(SUM([VeryActiveMinutes]) + SUM([FairlyActiveMinutes]) + SUM([LightlyActiveMinutes]))' />
      </column>
      <column caption='Sleep Hours' datatype='real' name='[Calculation_0740853220003842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([value])/60' />
      </column>
      <column caption='Active' datatype='real' name='[Calculation_1128156687773696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([LightlyActiveMinutes])+SUM([FairlyActiveMinutes])+SUM([VeryActiveMinutes]))/(SUM([LightlyActiveMinutes])+SUM([FairlyActiveMinutes])+SUM([VeryActiveMinutes])+SUM([SedentaryMinutes]))' />
      </column>
      <column caption='Sedentary' datatype='real' name='[Calculation_1128156690063361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SedentaryMinutes])/(SUM([LightlyActiveMinutes])+SUM([FairlyActiveMinutes])+SUM([VeryActiveMinutes])+SUM([SedentaryMinutes]))' />
      </column>
